{
  "name": "@fst/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "tsc -p tsconfig.json && vite build && electron dist/main.js",
    "smoke": "tsc -p tsconfig.json && vite build && node ./scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "electron": "^36.0.0",
    "playwright": "^1.54.2",
    "typescript": "^5.8.2",
    "vite": "^7.1.3"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
