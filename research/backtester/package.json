{
  "name": "@fst/backtester",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "dev": "node --import tsx src/index.ts",
    "tune:bb": "node --import tsx src/tune-bb-blocks.ts",
    "audit:bb": "node --import tsx src/audit-deterministic-bb.ts",
    "audit:auto-research": "node --import tsx src/audit-auto-research.ts",
    "replay:bb": "node --import tsx src/replay-deterministic-bb.ts",
    "doctor:research": "node --import tsx src/doctor-research-stack.ts",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/pg": "^8.15.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
