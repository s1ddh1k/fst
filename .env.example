# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fst

# Upbit
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Collector
COLLECTOR_MARKETS=KRW-BTC,KRW-ETH,KRW-XRP,KRW-SOL,KRW-DOGE
COLLECTOR_TIMEFRAMES=1m,5m,1h,1d
COLLECTOR_REQUEST_RETRY_COUNT=3
COLLECTOR_REQUEST_RETRY_DELAY_MS=500
COLLECTOR_UNIVERSE_NAME=krw-top
COLLECTOR_UNIVERSE_LIMIT=30

# Paper trader
PAPER_TRADER_HOST=127.0.0.1
PAPER_TRADER_PORT=8787
PAPER_STARTING_BALANCE=1000000
PAPER_FEE_RATE=0.0005
PAPER_SLIPPAGE_RATE=0.0003
PAPER_DEFAULT_REGIME=paper-trading-candidate
PAPER_DEFAULT_TIMEFRAME=5m
PAPER_DEFAULT_MARKET=KRW-BTC
PAPER_DEFAULT_RANK=1
PAPER_DEFAULT_MAX_EVENTS=0

# Desktop app
DESKTOP_API_BASE_URL=http://127.0.0.1:8787
